---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Segments from '../components/Segments.astro';
import Reinforce from '../components/Reinforce.astro';
import Formats from '../components/Formats.astro';
import DiagnosticCTA from '../components/DiagnosticCTA.astro';
import ServiceDetail from '../components/ServiceDetail.astro';
import Method from '../components/Method.astro';
import Cases from '../components/Cases.astro';
import Clients from '../components/Clients.astro';
import Reviews from '../components/Reviews.astro';
import Approach from '../components/Approach.astro';
import Team from '../components/Team.astro';
import Faq from '../components/Faq.astro';
import LeadForm from '../components/LeadForm.astro';
import Footer from '../components/Footer.astro';
import { services } from '../data/services';
import Container from '../components/ui/Container.astro';
---

<Base
  title="СинтезЛаб — системное развитие бизнеса"
  description="Командные и стратегические сессии, корпоративная медиация и коучинг лидеров. Бесплатная диагностика командной системы за 50 минут."
>
  <Header />
  <main>
    <!-- 1. Hero (white) -->
    <Hero />
    <!-- 2. Кому помогаем — ICP (surface) -->
    <Segments />
    <!-- 3. Как мы усиливаем бизнес (white) -->
    <Reinforce />
    <!-- 4. Основные форматы работы (surface) -->
    <Formats />
    <!-- 5. Бесплатная диагностика (ink — сильный смысловой разрыв) -->
    <DiagnosticCTA />

    <!-- 6. Что входит в каждый формат (white) -->
    <section class="cv-auto bg-white py-20 md:py-28">
      <Container>
        <h2 class="max-w-3xl text-3xl font-extrabold tracking-tight text-ink md:text-4xl">
          Что входит в каждый формат
        </h2>
        <p class="mt-4 max-w-2xl text-lg text-muted">
          Запрос, задачи и стоимость по каждому направлению. Точную смету формируем после бесплатной диагностики.
        </p>
        <div class="mt-10 space-y-6">
          {services.map((s) => <ServiceDetail service={s} />)}
        </div>
      </Container>
    </section>

    <!-- 7. Как строится работа — pipeline (surface) -->
    <Method />
    <!-- 8. Кейсы — интерактив (white) -->
    <Cases />
    <!-- 9. Нам доверяют (surface) -->
    <Clients />
    <!-- 10. Отзывы и признания (white) -->
    <Reviews />
    <!-- 11. Наш подход (surface) -->
    <Approach />
    <!-- 12. Наша команда (white) -->
    <Team />
    <!-- 13. FAQ (surface) -->
    <Faq />
    <!-- 14. Финальный CTA / форма (white) -->
    <LeadForm />
  </main>
  <Footer />
</Base>
