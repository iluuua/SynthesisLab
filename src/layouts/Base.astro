---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Системное развитие бизнеса — СинтезЛаб' } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="mask-icon" href="/favicon.svg" color="#3D5A7F" />

    {/* Preload только двух основных woff2: тело (400) и заголовки (800).
        Остальные веса и латиница грузятся по мере необходимости (font-display: swap). */}
    <link
      rel="preload"
      href="/fonts/mulish/mulish-cyrillic-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/mulish/mulish-cyrillic-800.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="ru_RU" />
    <meta name="twitter:card" content="summary" />
    <title>{title}</title>
  </head>
  <body class="font-sans">
    <slot />

    <script is:inline>
      (() => {
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
        const root = document.documentElement;
        const btn = document.getElementById('m-btn');
        const menu = document.getElementById('m-menu');
        const diagnosticFormSelector = '#diagnostic-form';

        const setMenu = (open) => {
          if (!btn || !menu) return;
          menu.classList.toggle('is-open', open);
          btn.setAttribute('aria-expanded', String(open));
        };

        const isLocalDev = () =>
          ['localhost', '127.0.0.1', '0.0.0.0'].includes(window.location.hostname);

        const warnMissingDiagnosticForm = () => {
          if (isLocalDev()) {
            console.warn('Diagnostic form target #diagnostic-form was not found.');
          }
        };

        const headerOffset = () => {
          const header = document.querySelector('header');
          return (header instanceof HTMLElement ? header.offsetHeight : 0) + 16;
        };

        const targetTop = (target) =>
          Math.max(target.getBoundingClientRect().top + window.scrollY - headerOffset(), 0);

        const scrollToTarget = (target, hash, ensureFinal = false) => {
          const scroll = (behavior) => {
            window.scrollTo({
              top: targetTop(target),
              behavior,
            });
          };

          scroll(reducedMotion.matches ? 'auto' : 'smooth');

          if (hash) history.replaceState(null, '', hash);

          if (!ensureFinal) return;

          const settle = () => {
            const top = targetTop(target);
            if (Math.abs(window.scrollY - top) > 3) {
              window.scrollTo({ top, behavior: 'auto' });
            }
          };

          window.setTimeout(settle, reducedMotion.matches ? 0 : 450);
          window.setTimeout(settle, reducedMotion.matches ? 0 : 900);
          window.setTimeout(settle, reducedMotion.matches ? 0 : 1400);
        };

        const scrollToDiagnosticForm = () => {
          const target = document.querySelector(diagnosticFormSelector);
          if (!(target instanceof HTMLElement)) {
            warnMissingDiagnosticForm();
            return false;
          }

          scrollToTarget(target, diagnosticFormSelector, true);
          return true;
        };

        const normalizePath = (path) => path.replace(/\/index\.html$/, '/');

        btn?.addEventListener('click', () => setMenu(!menu?.classList.contains('is-open')));

        // Единый делегированный обработчик кликов: плавный скролл по якорям + закрытие меню.
        // Никаких scroll-listener'ов — прокрутка остаётся нативной и не лагает.
        document.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const anchor = target.closest('a[href^="#"], a[href*="/#"]');
          if (anchor instanceof HTMLAnchorElement && anchor.hash.length > 1) {
            const samePage =
              anchor.origin === window.location.origin &&
              normalizePath(anchor.pathname) === normalizePath(window.location.pathname);
            if (samePage) {
              const id = decodeURIComponent(anchor.hash.slice(1));
              if (id === diagnosticFormSelector.slice(1)) {
                event.preventDefault();
                setMenu(false);
                scrollToDiagnosticForm();
              } else {
                const section = document.getElementById(id);
                if (section) {
                  event.preventDefault();
                  setMenu(false);
                  scrollToTarget(section, anchor.hash);
                }
              }
            }
          }

          if (menu?.classList.contains('is-open') && !target.closest('#m-menu, #m-btn')) {
            setMenu(false);
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') setMenu(false);
        });

        if (window.location.hash === diagnosticFormSelector) {
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              scrollToDiagnosticForm();
            });
          });
        }

        // Reveal только на уровне секций (≈12 узлов), один общий IntersectionObserver,
        // unobserve после появления. Карточки/логотипы/grid-элементы НЕ наблюдаются.
        const nodes = Array.from(
          document.querySelectorAll('main > section, [data-reveal]')
        );

        if (reducedMotion.matches || !('IntersectionObserver' in window)) {
          root.classList.add('motion-reduced');
          nodes.forEach((node) => node.classList.add('is-visible'));
          return;
        }

        nodes.forEach((node) => {
          node.classList.add('motion-reveal');
          if (node.getBoundingClientRect().top < window.innerHeight * 0.92) {
            node.classList.add('is-visible');
          }
        });

        root.classList.add('motion-ready');

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );

        nodes.forEach((node) => {
          if (!node.classList.contains('is-visible')) observer.observe(node);
        });
      })();
    </script>
  </body>
</html>
