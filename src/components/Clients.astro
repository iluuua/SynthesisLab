---
import Section from './ui/Section.astro';
import { clients, metrics } from '../data/content';
---

<Section
  id="klienty"
  tone="surface"
  title="Нам доверяют"
  subtitle="Команды и подразделения компаний, с которыми мы работали."
>
  <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
    {clients.map((client) => {
      // Единая белая карточка для всех логотипов: и прозрачные, и с белым/цветным
      // фоном (Saint-Gobain, Альфа-Банк) выглядят как часть одного ряда.
      const inner = (
        <img
          src={client.logo}
          alt={`Логотип ${client.name}`}
          width="160"
          height="48"
          class="max-h-11 w-auto max-w-[78%] object-contain opacity-80 transition-opacity duration-200 group-hover:opacity-100 group-focus-visible:opacity-100 group-active:opacity-100"
          loading="lazy"
          decoding="async"
        />
      );
      return (
        <li class="contents">
          {client.url ? (
            <a
              href={client.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Открыть сайт компании ${client.name}`}
              class="group flex h-24 items-center justify-center rounded-2xl border border-line bg-white px-5 transition duration-200 hover:-translate-y-1 hover:border-accent/30 hover:shadow-lg focus-visible:-translate-y-1 active:translate-y-0 active:shadow-md"
            >
              {inner}
            </a>
          ) : (
            <div
              class="group flex h-24 items-center justify-center rounded-2xl border border-line bg-white px-5"
              title={client.name}
            >
              {inner}
            </div>
          )}
        </li>
      );
    })}
  </ul>

  <div class="mt-12 grid gap-6 border-t border-line pt-10 sm:grid-cols-2 lg:grid-cols-4">
    {metrics.map((m) => (
      <div>
        <div class="text-3xl font-extrabold text-ink md:text-4xl">{m.value}</div>
        <div class="mt-2 text-sm text-muted">{m.label}</div>
      </div>
    ))}
  </div>
</Section>
