---
import Button from './ui/Button.astro';
import Icon from './ui/Icon.astro';
import { priceNote } from '../data/services';

interface Props {
  service: {
    anchor: string;
    title: string;
    priceFrom: string;
    detail: {
      request: string;
      solve: string[];
    };
  };
}

const { service } = Astro.props;
---

<div id={service.anchor} class="scroll-mt-24 border-t border-line py-12 first:border-t-0">
  <h3 class="text-2xl font-bold text-ink">{service.title}</h3>

  <div class="mt-6 grid gap-8 md:grid-cols-2">
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-muted">Запрос</p>
      <p class="mt-2 text-ink">{service.detail.request}</p>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-muted">Что решаем</p>
      <ul class="mt-2 space-y-2">
        {service.detail.solve.map((s: string) => (
          <li class="flex gap-2 text-ink">
            <Icon name="check" class="mt-1 shrink-0 text-accent" />
            <span>{s}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="mt-6 flex flex-wrap items-center gap-4">
    <span class="text-lg font-bold text-ink">{service.priceFrom}</span>
    <span class="max-w-md text-sm text-muted">{priceNote}</span>
  </div>

  <div class="mt-5">
    <Button variant="primary" href="#lead" class="!px-4 !py-2 text-sm">Получить диагностику</Button>
  </div>
</div>
