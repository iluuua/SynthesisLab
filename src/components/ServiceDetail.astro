---
import Button from './ui/Button.astro';
import Icon from './ui/Icon.astro';
import { priceNote } from '../data/services';

interface Props {
  service: {
    anchor: string;
    title: string;
    priceFrom: string;
    detail: {
      request: string;
      solve: string[];
    };
  };
}

const { service } = Astro.props;
---

<div
  id={service.anchor}
  class="scroll-mt-28 overflow-hidden rounded-2xl border border-line bg-white shadow-sm"
>
  <div class="border-l-4 border-accent p-7 md:p-9">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <h3 class="text-2xl font-bold text-ink">{service.title}</h3>
      <span class="rounded-full bg-surface px-4 py-1.5 text-sm font-bold text-ink">
        {service.priceFrom}
      </span>
    </div>

    <div class="mt-6 grid gap-8 md:grid-cols-2">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-accent">Запрос</p>
        <p class="mt-2 leading-7 text-ink">{service.detail.request}</p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-accent">Что решаем</p>
        <ul class="mt-2 space-y-2">
          {service.detail.solve.map((s: string) => (
            <li class="flex gap-2 text-ink">
              <Icon name="check" class="mt-1 shrink-0 text-accent" />
              <span>{s}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-7 flex flex-wrap items-center gap-x-5 gap-y-3 border-t border-line pt-6">
      <Button variant="primary" href="#diagnostic-form" class="!px-4 !py-2 text-sm">Получить диагностику</Button>
      <span class="max-w-md text-sm text-muted">{priceNote}</span>
    </div>
  </div>
</div>
