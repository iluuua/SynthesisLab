---
import Section from './ui/Section.astro';
import CaseCard from './CaseCard.astro';
import { cases } from '../data/cases';
---

<Section id="keysy" tone="surface" eyebrow="Опыт" title="Кейсы">
  <div class="grid gap-6 md:grid-cols-2">
    {cases.map((c) => (
      <CaseCard item={c} />
    ))}
  </div>
</Section>
