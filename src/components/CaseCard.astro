---
import Icon from './ui/Icon.astro';

interface Props {
  item: any;
}

const { item } = Astro.props;
---

<article
  class:list={[
    'rounded-2xl border bg-white p-7',
    item.featured ? 'border-accent ring-1 ring-accent/20' : 'border-line',
  ]}
>
  {item.client && (
    <span class="inline-block rounded-full bg-ink/5 px-3 py-1 text-xs font-semibold text-ink">
      {item.client}
    </span>
  )}

  <h3 class="mt-3 text-lg font-bold text-ink">{item.title}</h3>

  {item.scale && (
    <p class="mt-2 text-xs font-semibold uppercase tracking-wide text-muted">{item.scale}</p>
  )}

  <div class="mt-4 space-y-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-muted">
        Ситуация
      </p>
      <p class="mt-1 text-sm text-ink">{item.situation}</p>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-muted">
        Что делали
      </p>
      <ul class="mt-1 space-y-1">
        {item.work.slice(0, 3).map((r: string) => (
          <li class="flex gap-2 text-sm text-ink">
            <Icon name="arrow" class="mt-0.5 h-4 w-4 shrink-0 text-accent" />
            <span>{r}</span>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-muted">
        Результат
      </p>
      <ul class="mt-1 space-y-1">
        {item.result.slice(0, 3).map((r: string) => (
          <li class="flex gap-2 text-sm text-ink">
            <Icon name="check" class="mt-0.5 shrink-0 text-accent" />
            <span>{r}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</article>
