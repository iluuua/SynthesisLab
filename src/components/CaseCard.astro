---
import Icon from './ui/Icon.astro';

interface Props {
  item: any;
}

const { item } = Astro.props;
---

<article
  class:list={[
    'flex flex-col rounded-2xl border bg-white p-7 transition hover:shadow-md',
    item.featured ? 'border-accent/60 ring-1 ring-accent/20' : 'border-line',
  ]}
>
  <div class="flex flex-wrap items-center justify-between gap-2">
    {item.client ? (
      <span
        class:list={[
          'rounded-full px-3 py-1 text-xs font-bold',
          item.featured ? 'bg-accent/10 text-accent' : 'bg-ink/5 text-ink',
        ]}
      >
        {item.client}
      </span>
    ) : (
      <span class="text-xs font-semibold uppercase tracking-widest text-muted">Кейс</span>
    )}
    {item.scale && <span class="text-xs font-medium text-muted">{item.scale}</span>}
  </div>

  <h3 class="mt-4 text-lg font-bold leading-snug text-ink">{item.title}</h3>
  <p class="mt-3 text-sm leading-6 text-muted">{item.situation}</p>

  <div class="mt-5 grid gap-5 border-t border-line pt-5">
    <div>
      <p class="mb-1.5 text-xs font-semibold uppercase tracking-widest text-ink/60">Что делали</p>
      <ul class="space-y-1">
        {item.work.slice(0, 3).map((r: string) => (
          <li class="flex gap-2 text-sm text-ink">
            <Icon name="arrow" class="mt-0.5 h-4 w-4 shrink-0 text-accent" />
            <span>{r}</span>
          </li>
        ))}
      </ul>
    </div>
    <div>
      <p class="mb-1.5 text-xs font-semibold uppercase tracking-widest text-ink/60">Результат</p>
      <ul class="space-y-1">
        {item.result.slice(0, 3).map((r: string) => (
          <li class="flex gap-2 text-sm text-ink">
            <Icon name="check" class="mt-0.5 shrink-0 text-accent" />
            <span>{r}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</article>
