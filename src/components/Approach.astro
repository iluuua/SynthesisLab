---
import Section from "./ui/Section.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { approach } from "../data/content";
import diamond from "../assets/approach/diamond.png";
import handsHeart from "../assets/approach/hands-heart.png";
import shapes from "../assets/approach/shapes.png";
import gear from "../assets/approach/gear.png";

const icons: Record<string, ImageMetadata> = {
  diamond,
  "hands-heart": handsHeart,
  shapes,
  gear,
};
---

<Section tone="surface" title="Наш подход" subtitle={approach.lead} center>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {approach.values.map((v) => (
      <div class="flex flex-col items-center gap-5 rounded-2xl border border-line bg-white p-7 text-center">
        <Image
          src={icons[v.icon]}
          alt=""
          width={128}
          height={128}
          class="h-16 w-16"
          aria-hidden="true"
        />
        <p class="font-semibold leading-7 text-ink">{v.text}</p>
      </div>
    ))}
  </div>
</Section>
