---
import Section from './ui/Section.astro';
import Button from './ui/Button.astro';
import Icon from './ui/Icon.astro';
import { diagnostic } from '../data/content';
---

<Section id="diagnostika" tone="ink">
  <div class="grid items-center gap-10 md:grid-cols-[0.95fr_1.05fr]">
    <div>
      <h2 class="text-3xl font-extrabold leading-tight text-white md:text-5xl">
        {diagnostic.heading}
      </h2>
      <p class="mt-5 max-w-xl text-lg text-periwinkle">
        Первый шаг — {diagnostic.duration} разговора о вашей команде. Бесплатно, без подготовки и обязательств.
      </p>
      <div class="mt-8">
        <Button variant="primary" href="#diagnostic-form">
          Получить диагностику
        </Button>
      </div>
    </div>

    <div class="rounded-2xl border border-white/15 bg-white/[0.08] p-7">
      <p class="text-sm font-semibold uppercase tracking-wide text-periwinkle">
        {diagnostic.intro}
      </p>
      <ul class="mt-5 space-y-4">
        {diagnostic.outcomes.map((o) => (
          <li class="flex gap-3 text-white">
            <Icon name="check" class="mt-0.5 shrink-0 text-accent" />
            <span>{o}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</Section>
