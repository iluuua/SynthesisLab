---
import Section from './ui/Section.astro';
import { method } from '../data/content';
---

<Section
  id="kak-stroitsya"
  tone="surface"
  title="Как строится работа"
  subtitle="Понятный путь от первого разговора до закреплённого результата — без сюрпризов."
>
  <ol class="relative mx-auto max-w-3xl">
    {/* вертикальная линия pipeline */}
    <span
      aria-hidden="true"
      class="absolute left-[19px] top-2 bottom-2 w-px bg-line md:left-[23px]"
    ></span>

    {method.map((s) => (
      <li class="relative flex gap-5 pb-8 last:pb-0 md:gap-6">
        <span
          class="relative z-10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white text-base font-extrabold tabular-nums text-accent ring-1 ring-line md:h-12 md:w-12 md:text-lg"
        >
          {s.n}
        </span>
        <div class="pt-1.5 md:pt-2">
          <h3 class="text-lg font-bold leading-snug text-ink">{s.title}</h3>
          <p class="mt-1.5 leading-7 text-muted">{s.text}</p>
        </div>
      </li>
    ))}
  </ol>
</Section>
