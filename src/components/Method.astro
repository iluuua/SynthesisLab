---
import Section from './ui/Section.astro';
import { method } from '../data/content';
---

<Section title="Как строится работа" subtitle="Пять шагов — от первого разговора до закреплённого результата.">
  <ol class="relative grid gap-x-6 gap-y-10 sm:grid-cols-2 md:grid-cols-5">
    <div
      aria-hidden="true"
      class="absolute left-5 right-5 top-6 hidden h-0.5 bg-line md:block"
    ></div>
    {method.map((s) => (
      <li class="relative">
        <span class="relative z-10 flex h-12 w-12 items-center justify-center rounded-full bg-ink text-lg font-bold text-white ring-4 ring-white">
          {s.n}
        </span>
        <h3 class="mt-4 font-bold text-ink">{s.title}</h3>
        <p class="mt-2 text-sm leading-6 text-muted">{s.text}</p>
      </li>
    ))}
  </ol>
</Section>
