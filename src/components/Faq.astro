---
import Section from "./ui/Section.astro";
import { faq } from "../data/content";
---

<Section id="faq" eyebrow="FAQ" title="Вопросы и ответы">
  <div class="mx-auto max-w-3xl divide-y divide-line">
    {faq.map((f) => (
      <details class="group py-5">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-ink">
          <span>{f.q}</span>
          <span class="text-2xl leading-none text-accent motion-safe:transition group-open:rotate-45">+</span>
        </summary>
        <p class="mt-3 text-muted">{f.a}</p>
      </details>
    ))}
  </div>
</Section>
