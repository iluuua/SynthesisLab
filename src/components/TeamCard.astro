---
import { Image } from "astro:assets";

interface Props {
  member: any;
}

const { member } = Astro.props;
---

<article>
  {member.photo && (
    <Image
      src={member.photo}
      alt={member.name}
      width={480}
      height={600}
      class="aspect-[4/5] w-full rounded-2xl object-cover object-[50%_18%]"
    />
  )}
  <h3 class="mt-4 text-lg font-bold text-ink">{member.name}</h3>
  <p class="text-sm text-accent">{member.role}</p>
  <ul class="mt-3 space-y-1.5">
    {member.bio.map((b: string) => (
      <li class="text-sm text-muted">{b}</li>
    ))}
  </ul>
</article>
