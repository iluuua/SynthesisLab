---
import Button from './ui/Button.astro';

interface Props {
  service: any;
}

const { service } = Astro.props;
---

<div class="flex min-h-[280px] flex-col rounded-2xl border border-line bg-white p-7 transition hover:-translate-y-0.5 hover:shadow-md">
  <p class="text-xs font-semibold uppercase tracking-widest text-accent">Формат</p>
  <h3 class="mt-3 text-xl font-bold text-ink">{service.title}</h3>
  <p class="text-muted">{service.blurb}</p>
  <div class="mt-auto flex flex-wrap items-center gap-4 pt-2">
    <Button variant="primary" href="#lead" class="!px-4 !py-2 text-sm">
      Получить диагностику
    </Button>
    <a
      href={'#' + service.anchor}
      class="text-sm font-semibold text-accent hover:underline"
    >
      Подробнее →
    </a>
  </div>
</div>
