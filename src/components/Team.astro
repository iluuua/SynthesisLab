---
import Section from './ui/Section.astro';
import TeamCard from './TeamCard.astro';
import { team } from '../data/team';
---

<Section
  id="komanda"
  tone="white"
  title="Наша команда"
  subtitle="Executive- и командные коучи, фасилитаторы и организационные консультанты."
  center
>
  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
    {team.map((m) => (
      <TeamCard member={m} />
    ))}
  </div>
</Section>
