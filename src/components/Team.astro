---
import Section from "./ui/Section.astro";
import TeamCard from "./TeamCard.astro";
import { team, projectTeamNote } from "../data/team";
---

<Section id="komanda" title="Наша команда" center>
  <div class="grid gap-8 lg:grid-cols-[0.72fr_1.28fr]">
    <div class="self-start rounded-2xl bg-surface p-7 text-left">
      <p class="text-sm font-semibold uppercase tracking-widest text-accent">
        {projectTeamNote.title}
      </p>
      <p class="mt-4 text-muted">
        {projectTeamNote.text}
      </p>
    </div>
    <div class="grid gap-8 sm:grid-cols-2">
      {team.map((m) => (
        <TeamCard member={m} />
      ))}
    </div>
  </div>
</Section>
