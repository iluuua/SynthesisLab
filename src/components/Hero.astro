---
import Container from './ui/Container.astro';
import Button from './ui/Button.astro';
import { Image } from 'astro:assets';
import { site, contacts, hero, metrics, diagnostic } from '../data/content';
import foundersHero from '../assets/photos/founders-hero.jpg';
---

<section class="relative overflow-hidden bg-white">
  <Container>
    <div class="relative grid min-h-[600px] items-center gap-12 py-14 md:grid-cols-[1.02fr_0.98fr] md:py-16 lg:min-h-[680px]">
      <div>
        <h1
          class="max-w-4xl text-4xl font-extrabold leading-[1.08] text-ink md:text-5xl lg:text-6xl"
        >
          {hero.h1}
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-muted md:text-xl">
          {hero.sub}
        </p>
        <ul class="mt-6 grid max-w-xl gap-2.5">
          {hero.bullets.map((b) => (
            <li class="flex items-start gap-2.5 text-ink">
              <span aria-hidden="true" class="mt-1.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-accent/10">
                <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 text-accent" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              </span>
              <span class="leading-6">{b}</span>
            </li>
          ))}
        </ul>
        <div class="mt-9 flex flex-wrap items-center gap-3">
          <Button variant="primary" href="#diagnostic-form">
            {site.ctaLabel}
          </Button>
          <a
            href={contacts.telegramKatya.url}
            aria-label="Написать в Telegram"
            class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-accent text-white shadow-sm transition hover:brightness-95 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg viewBox="0 0 49 49" class="h-6 w-6" fill="currentColor" aria-hidden="true">
              <path d="M32.9849 18.3815C33.1252 17.4609 32.2636 16.7343 31.4579 17.0937L15.4104 24.2512C14.8326 24.509 14.8749 25.398 15.4742 25.5919L18.7835 26.6625C19.4152 26.8668 20.0991 26.7612 20.6506 26.3741L28.1118 21.1375C28.3368 20.9795 28.5821 21.3045 28.3899 21.5059L23.0191 27.131C22.4981 27.6767 22.6015 28.6013 23.2282 29.0005L29.2413 32.8312C29.9158 33.2608 30.7834 32.8292 30.9095 32.0013L32.9849 18.3815Z" />
            </svg>
          </a>
        </div>
        <dl class="mt-10 grid max-w-xl grid-cols-2 gap-4 sm:grid-cols-4">
          {metrics.map((m) => (
            <div class="border-t border-line pt-3">
              <dt class="text-2xl font-extrabold text-ink">{m.value}</dt>
              <dd class="mt-1 text-xs leading-4 text-muted">{m.label}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="relative mx-auto w-full max-w-md md:mx-0 md:max-w-none">
        <div class="group relative overflow-hidden rounded-3xl bg-surface shadow-md ring-1 ring-line transition-shadow duration-300 hover:shadow-xl">
          <Image
            src={foundersHero}
            alt="Татьяна Петрова и Екатерина Деревяшкина, соосновательницы СинтезЛаб"
            width={780}
            height={975}
            class="aspect-[4/5] w-full object-cover object-[50%_28%] transition-transform duration-700 ease-out will-change-transform motion-safe:group-hover:scale-[1.045]"
            loading="eager"
            densities={[1.5, 2]}
          />
        </div>
        <div class="absolute -bottom-6 left-4 right-4 rounded-2xl border border-line bg-white/95 p-5 shadow-lg backdrop-blur-sm sm:left-6 sm:right-6">
          <p class="text-sm font-semibold text-accent">{diagnostic.heading}</p>
          <p class="mt-2 text-base font-bold leading-6 text-ink sm:text-lg">
            За {diagnostic.duration} — фокусы, точки потери эффективности и следующий шаг.
          </p>
        </div>
      </div>
    </div>
  </Container>
</section>
