---
import Section from './ui/Section.astro';
import { reinforce } from '../data/content';
---

<Section
  tone="surface"
  title="Как мы усиливаем эффективность бизнеса"
  subtitle="Работаем с системой в целом — со связями между лидерами, командами, целями и решениями."
>
  <div class="grid gap-5 sm:grid-cols-2">
    {reinforce.map((r, i) => (
      <article class="group relative overflow-hidden rounded-2xl border border-line bg-white p-7 transition duration-200 hover:-translate-y-1 hover:border-accent/40 hover:shadow-lg">
        <span
          aria-hidden="true"
          class="absolute left-0 top-0 h-full w-1 bg-transparent transition-colors duration-200 group-hover:bg-accent"
        ></span>
        <div class="flex items-baseline gap-3">
          <span class="text-sm font-extrabold tabular-nums text-accent">
            {String(i + 1).padStart(2, '0')}
          </span>
          <h3 class="text-xl font-bold text-ink">{r.title}</h3>
        </div>
        <p class="mt-3 leading-7 text-muted">{r.text}</p>
      </article>
    ))}
  </div>
</Section>
