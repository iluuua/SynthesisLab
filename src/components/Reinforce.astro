---
import Section from './ui/Section.astro';
import { reinforce } from '../data/content';
---

<Section tone="surface" title="Как мы усиливаем эффективность бизнеса">
  <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
    <div class="rounded-2xl bg-white p-7">
      <p class="text-sm font-semibold uppercase tracking-widest text-accent">Система команды</p>
      <h3 class="mt-4 text-2xl font-extrabold leading-tight text-ink">
        Диагностика показывает, где команда теряет энергию, скорость и ясность.
      </h3>
      <p class="mt-4 text-muted">
        Дальше мы работаем не с симптомами, а с взаимодействием между лидерами, командами, целями и решениями.
      </p>
      <div class="mt-8 grid grid-cols-2 gap-3 text-sm font-semibold text-ink">
        <span class="rounded-xl border border-line px-4 py-3">Лидеры</span>
        <span class="rounded-xl border border-line px-4 py-3">Коммуникации</span>
        <span class="rounded-xl border border-line px-4 py-3">Роли</span>
        <span class="rounded-xl border border-line px-4 py-3">Вектор</span>
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {reinforce.map((r, index) => (
        <article class="rounded-2xl border border-line bg-white p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-ink text-sm font-bold text-white">
            {String(index + 1).padStart(2, '0')}
          </div>
          <h3 class="mt-5 text-xl font-bold text-ink">{r.title}</h3>
          <p class="mt-3 text-muted">{r.text}</p>
        </article>
      ))}
    </div>
  </div>
</Section>
