---
interface Props {
  href?: string;
  variant?: 'primary' | 'ghost' | 'light';
  type?: 'button' | 'submit';
  class?: string;
}

const {
  href,
  variant = 'primary',
  type = 'button',
  class: className = '',
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-xl px-6 py-3 font-semibold transition-all duration-300 ease-out hover:shadow-md active:scale-[0.99] disabled:cursor-not-allowed disabled:opacity-70';

const variants: Record<string, string> = {
  primary: 'bg-accent text-white hover:brightness-95 focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2',
  ghost:
    'border border-ink/30 text-ink hover:bg-ink/5 focus-visible:ring-2 focus-visible:ring-ink/40 focus-visible:ring-offset-2',
  light:
    'bg-white text-ink hover:bg-surface focus-visible:ring-2 focus-visible:ring-ink/40 focus-visible:ring-offset-2',
};

const classes = [base, variants[variant], className].join(' ');
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}
