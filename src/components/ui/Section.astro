---
import Container from './Container.astro';

interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  tone?: 'white' | 'surface' | 'ink';
}

const { id, eyebrow, title, subtitle, tone = 'white' } = Astro.props;

const bgClass =
  tone === 'ink'
    ? 'bg-ink text-white'
    : tone === 'surface'
      ? 'bg-surface'
      : 'bg-white';
const headingColor = tone === 'ink' ? 'text-white' : 'text-ink';
const subColor = tone === 'ink' ? 'text-periwinkle' : 'text-muted';
const hasHeading = !!(eyebrow || title || subtitle);
---

<section id={id} class:list={['py-20 md:py-28', bgClass]}>
  <Container>
    {eyebrow && (
      <p class="text-sm font-semibold uppercase tracking-widest text-accent mb-3">
        {eyebrow}
      </p>
    )}
    {title && (
      <h2
        class:list={[
          'text-3xl md:text-4xl font-extrabold tracking-tight max-w-3xl',
          headingColor,
        ]}
      >
        {title}
      </h2>
    )}
    {subtitle && (
      <p class:list={['mt-4 text-lg max-w-2xl', subColor]}>
        {subtitle}
      </p>
    )}
    <div class={hasHeading ? 'mt-12' : undefined}>
      <slot />
    </div>
  </Container>
</section>
